# =====================================================
# InvSys — Variables de Entorno
# =====================================================
# Copiar este archivo como .env y ajustar los valores.
# NUNCA subir el archivo .env al repositorio.
# =====================================================

# Entorno: development | production
APP_ENV=production

# Base de datos (credenciales del hosting)
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=invsys_db
DB_USERNAME=root
DB_PASSWORD=

DB_CHARSET=utf8mb4

# URL base del proyecto (ajustar según el hosting)
# -----------------------------------------------
# Si el sitio está en la raíz del dominio:
#   APP_BASE_URL=
#
# Si está en un subdirectorio (ej: tudominio.com/invsys):
#   APP_BASE_URL=/invsys/public
#
# Desarrollo local con XAMPP:
#   APP_BASE_URL=/invsys/public
# -----------------------------------------------
APP_BASE_URL=/invsys/public

# Configuración de correo
# -----------------------------------------------
# Email y nombre que aparecerán como remitente
# en las notificaciones del sistema.
# -----------------------------------------------
MAIL_FROM_ADDRESS=noreply@tudominio.com
MAIL_FROM_NAME=InvSys
